# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Claude temp files
tmpclaude-*

# Supabase temp files
supabase/.temp/

# Dev artifacts
assets/svg-source/
test-*.ps1
recipe_classification_*.json

# Claude.ai delivery & export folders
claude_update/
claude_project_upload/

# Superseded edge function versions
supabase/functions/extract-recipe-v[0-9]*/
supabase/functions/extract-recipe-v10.*/
supabase/functions/extract-recipe-v10-2/

# Claude.ai project knowledge sync staging — populated by CC, cleared after upload
_pk_sync/*
!_pk_sync/.gitkeep

# Incoming CC prompt files from Claude.ai planning sessions
external_documents/

# Ephemeral Claude.ai session context — see _claudeai_context/README.md
_claudeai_context/*
!_claudeai_context/.gitkeep
!_claudeai_context/README.md

# Local runtime / dev artifacts (2026-05-19 close-out)
metro.log
set-mary-password.js
.claude/settings.local.json
